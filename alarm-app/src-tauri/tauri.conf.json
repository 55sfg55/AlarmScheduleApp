{
  "productName": "alarm-app",
  "version": "0.1.0",
  "identifier": "com.s.alarm-app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "alarm-app",
        "width": 800,
        "height": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": ["**"]}
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "scheme": ["myalarmapp2"] }
      ]
    },
    "fs": {
      "withGlobalTauri": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}